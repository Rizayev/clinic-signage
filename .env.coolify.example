# ============================================================
# Coolify Environment Variables — Clinic Signage (prod)
# Paste these into Coolify > your app > Environment Variables.
# Values marked <FILL> must be set by you.
# ============================================================

APP_NAME=Clinic Signage
APP_ENV=production
APP_DEBUG=false
# Fresh key — generate with: php artisan key:generate --show
APP_KEY=base64:<FILL>
# Main domain (https). Drives media URLs (Storage::url). No trailing slash.
APP_URL=https://<your-domain>

APP_LOCALE=ru
APP_TIMEZONE=Asia/Baku
LOG_LEVEL=warning

# --- Database: Coolify-managed MySQL resource ---
DB_HOST=<mysql-internal-host>      # e.g. the Coolify MySQL service hostname
DB_PORT=3306
DB_DATABASE=<FILL>
DB_USERNAME=<FILL>
DB_PASSWORD=<FILL>

# --- Reverb (server-side publish): leave as-is, internal compose network ---
REVERB_APP_ID=227877
REVERB_APP_KEY=<FILL-new-random>          # rotate from repo value
REVERB_APP_SECRET=<FILL-new-random>       # rotate from repo value

# --- Reverb (browser client): BAKED at build time, must be PUBLIC wss endpoint ---
# Point a subdomain (e.g. reverb.<your-domain>) at the `reverb` service, port 8080.
VITE_REVERB_HOST=reverb.<your-domain>
VITE_REVERB_PORT=443
VITE_REVERB_SCHEME=https

MAIL_MAILER=log
